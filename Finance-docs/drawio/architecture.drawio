        <mxCell id="QgS3yToziMC3se3RhHh5-17" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7C3AED;strokeColor=#6D28D9;fontColor=#FFFFFF;fontSize=11;" value="&lt;b&gt;⑥ process_invoice_image(image_bytes)&lt;/b&gt;&lt;br/&gt;np.frombuffer(image_bytes) → cv2.imdecode(arr, IMREAD_COLOR)&lt;br/&gt;→ numpy BGR image | Lỗi nếu không decode được" vertex="1">
          <mxGeometry height="75" width="510" x="961" y="64" as="geometry" />
        </mxCell>
        <mxCell id="QgS3yToziMC3se3RhHh5-18" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7C3AED;strokeColor=#6D28D9;fontColor=#FFFFFF;fontSize=11;" value="&lt;b&gt;⑦ PaddleOCR Singleton — _get_paddle_ocr()&lt;/b&gt;&lt;br/&gt;PaddleOCR(use_angle_cls=True, lang=&quot;vi&quot;, show_log=False)&lt;br/&gt;Lazy init (Double-Checked Locking) — chỉ khởi tạo 1 lần&lt;br/&gt;ocr.ocr(img, cls=True) → [[box, (text, confidence)],...]" vertex="1">
          <mxGeometry height="95" width="510" x="961" y="174" as="geometry" />
        </mxCell>
        <mxCell id="QgS3yToziMC3se3RhHh5-19" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7C3AED;strokeColor=#6D28D9;fontColor=#FFFFFF;fontSize=11;" value="&lt;b&gt;⑧ Build OCR Blocks + Sort by Y&lt;/b&gt;&lt;br/&gt;Mỗi region: center_x = avg(box.x) | center_y = avg(box.y)&lt;br/&gt;blocks = [{text, x, y},...] | sort(key=y) → thứ tự từ trên xuống" vertex="1">
          <mxGeometry height="75" width="370" x="1031" y="319" as="geometry" />
        </mxCell>
        <mxCell id="QgS3yToziMC3se3RhHh5-20" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7C3AED;strokeColor=#6D28D9;fontColor=#FFFFFF;fontSize=11;" value="&lt;b&gt;⑨ Strategy Router — Phân loại loại hóa đơn&lt;/b&gt;&lt;br/&gt;full_normalized_text = normalize_text(join(all blocks))&lt;br/&gt;(Lowercase, strip diacritics, remove special chars)" vertex="1">
          <mxGeometry height="75" width="320" x="1056" y="424" as="geometry" />
        </mxCell>
        <mxCell id="QgS3yToziMC3se3RhHh5-21" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#F59E0B;strokeColor=#D97706;fontColor=#1F2937;fontSize=11;verticalAlign=middle;" value="&lt;b&gt;Loại hóa đơn?&lt;/b&gt;" vertex="1">
          <mxGeometry height="80" width="270" x="1341" y="524" as="geometry" />
        </mxCell>
        <mxCell id="QgS3yToziMC3se3RhHh5-22" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0369A1;strokeColor=#075985;fontColor=#FFFFFF;fontSize=11;align=left;" value="&lt;b&gt;⑩a Strategy 1: DIGITAL&lt;/b&gt;&lt;br/&gt;&lt;i&gt;Kích hoạt: &#39;chi tiet&#39; | &#39;giao dich&#39;&lt;/i&gt;&lt;br/&gt;&lt;b&gt;ShopeePay / Ví điện tử&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;Merchant: &#39;Hóa đơn điện tử / App&#39;&lt;br/&gt;Amount: max(currency nums) trong top 45%&lt;br/&gt;Date: extract_vietnamese_date() ||&lt;br/&gt;       extract_standard_date()&lt;br/&gt;&lt;i&gt;&#39;DD tháng MM năm YYYY&#39; → ISO&lt;/i&gt;" vertex="1">
          <mxGeometry height="195" width="270" x="951" y="584" as="geometry" />
        </mxCell>
        <mxCell id="QgS3yToziMC3se3RhHh5-23" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0369A1;strokeColor=#075985;fontColor=#FFFFFF;fontSize=11;align=left;" value="&lt;b&gt;⑩b Strategy 2: TABULAR&lt;/b&gt;&lt;br/&gt;&lt;i&gt;Kích hoạt: &#39;gtgt&#39; | &#39;dien luc&#39; | &#39;mau so&#39;&lt;/i&gt;&lt;br/&gt;&lt;b&gt;EVN / Hóa đơn GTGT&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;Merchant: top 20%, tìm &#39;cong ty&#39;/&#39;dien luc&#39;&lt;br/&gt;  (skip &#39;mau so&#39;, &#39;ky hieu&#39;)&lt;br/&gt;Amount: tìm &#39;tong cong&#39;/&#39;thanh toan&#39;&lt;br/&gt;  → same Y-axis (±25px) → rightmost block&lt;br/&gt;Date: extract_standard_date() &#39;DD/MM/YYYY&#39;" vertex="1">
          <mxGeometry height="210" width="270" x="1341" y="634" as="geometry" />
        </mxCell>
        <mxCell id="QgS3yToziMC3se3RhHh5-24" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0369A1;strokeColor=#075985;fontColor=#FFFFFF;fontSize=11;align=left;" value="&lt;b&gt;⑩c Strategy 3: RETAIL (Default)&lt;/b&gt;&lt;br/&gt;&lt;i&gt;Không khớp 2 pattern trên&lt;/i&gt;&lt;br/&gt;&lt;b&gt;Katinat / Bong Trà / Cửa hàng lẻ&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;Merchant: top 15%, join 2 blocks đầu&lt;br/&gt;  (skip status bar: HH:MM, %)&lt;br/&gt;Blacklist: &#39;chiet khau&#39;,&#39;giam&#39;,&#39;khuyen mai&#39;&lt;br/&gt;Amount: tìm &#39;thanh toan&#39;/&#39;tong tien&#39;&lt;br/&gt;  → same block || same Y (±25px)&lt;br/&gt;  Fallback: max() in bottom 30%&lt;br/&gt;Date: extract_standard_date()" vertex="1">
          <mxGeometry height="230" width="290" x="1681" y="604" as="geometry" />
        </mxCell>
        <mxCell id="QgS3yToziMC3se3RhHh5-25" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7C3AED;strokeColor=#6D28D9;fontColor=#FFFFFF;fontSize=11;" value="&lt;b&gt;⑪ Fallback cho trường rỗng&lt;/b&gt;&lt;br/&gt;merchantName = &#39;Không rõ&#39; nếu rỗng&lt;br/&gt;totalAmount = 0 nếu không tìm được số tiền&lt;br/&gt;transactionDate = now() (UTC) nếu không có ngày" vertex="1">
          <mxGeometry height="80" width="510" x="1221" y="884" as="geometry" />
        </mxCell>
        <mxCell id="QgS3yToziMC3se3RhHh5-26" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#16A34A;strokeColor=#15803D;fontColor=#FFFFFF;fontSize=11;" value="&lt;b&gt;⑫ ai-service Response (HTTP 200)&lt;/b&gt;&lt;br/&gt;{&quot;success&quot;: true, &quot;data&quot;: {merchantName, totalAmount, transactionDate}}&lt;br/&gt;→ service-transaction normalizeAmount() + normalizeDate()" vertex="1">
