      vertex="1" parent="1">
      <mxGeometry x="950" y="635" width="140" height="75" as="geometry" />
    </mxCell>

    <mxCell id="12" value="&lt;b&gt;503 Error&lt;/b&gt;&lt;br/&gt;PaddleOCR service không&lt;br/&gt;phản hồi (timeout/down)"
