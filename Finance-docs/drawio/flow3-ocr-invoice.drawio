    <!-- Client → GW -->
    <mxCell id="51" value="multipart/form-data" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#0284C7;strokeWidth=2;" edge="1" source="4" target="5" parent="1">
