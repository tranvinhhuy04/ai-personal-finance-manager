    <!-- decode → PaddleOCR -->
    <mxCell id="60" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#7C3AED;strokeWidth=2;" edge="1" source="13" target="14" parent="1">
      <mxGeometry relative="1" as="geometry" />
