    <!-- AI SERVICE — Decode Image -->
    <mxCell id="13" value="&lt;b&gt;⑥ process_invoice_image(image_bytes)&lt;/b&gt;&lt;br/&gt;np.frombuffer(image_bytes) → cv2.imdecode(arr, IMREAD_COLOR)&lt;br/&gt;→ numpy BGR image | Lỗi nếu không decode được"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7C3AED;strokeColor=#6D28D9;fontColor=#FFFFFF;fontSize=11;"
      vertex="1" parent="1">
      <mxGeometry x="380" y="855" width="510" height="75" as="geometry" />
    </mxCell>

    <!-- PaddleOCR -->
    <mxCell id="14" value="&lt;b&gt;⑦ PaddleOCR Singleton — _get_paddle_ocr()&lt;/b&gt;&lt;br/&gt;PaddleOCR(use_angle_cls=True, lang=&quot;vi&quot;, show_log=False)&lt;br/&gt;Lazy init (Double-Checked Locking) — chỉ khởi tạo 1 lần&lt;br/&gt;ocr.ocr(img, cls=True) → [[box, (text, confidence)],...]"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7C3AED;strokeColor=#6D28D9;fontColor=#FFFFFF;fontSize=11;"
      vertex="1" parent="1">
      <mxGeometry x="380" y="975" width="510" height="95" as="geometry" />
    </mxCell>

    <!-- Build blocks -->
    <mxCell id="15" value="&lt;b&gt;⑧ Build OCR Blocks + Sort by Y&lt;/b&gt;&lt;br/&gt;Mỗi region: center_x = avg(box.x) | center_y = avg(box.y)&lt;br/&gt;blocks = [{text, x, y},...] | sort(key=y) → thứ tự từ trên xuống"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7C3AED;strokeColor=#6D28D9;fontColor=#FFFFFF;fontSize=11;"
      vertex="1" parent="1">
      <mxGeometry x="380" y="1120" width="510" height="75" as="geometry" />
    </mxCell>

    <!-- Strategy Router -->
    <mxCell id="16" value="&lt;b&gt;⑨ Strategy Router — Phân loại loại hóa đơn&lt;/b&gt;&lt;br/&gt;full_normalized_text = normalize_text(join(all blocks))&lt;br/&gt;(Lowercase, strip diacritics, remove special chars)"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7C3AED;strokeColor=#6D28D9;fontColor=#FFFFFF;fontSize=11;"
      vertex="1" parent="1">
      <mxGeometry x="380" y="1240" width="510" height="75" as="geometry" />
    </mxCell>

    <mxCell id="17" value="&lt;b&gt;Loại hóa đơn?&lt;/b&gt;"
      style="rhombus;whiteSpace=wrap;html=1;fillColor=#F59E0B;strokeColor=#D97706;fontColor=#1F2937;fontSize=11;verticalAlign=middle;"
      vertex="1" parent="1">
      <mxGeometry x="500" y="1360" width="270" height="80" as="geometry" />
    </mxCell>

    <!-- Strategy 1: DIGITAL -->
    <mxCell id="18" value="&lt;b&gt;⑩a Strategy 1: DIGITAL&lt;/b&gt;&lt;br/&gt;&lt;i&gt;Kích hoạt: 'chi tiet' | 'giao dich'&lt;/i&gt;&lt;br/&gt;&lt;b&gt;ShopeePay / Ví điện tử&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;Merchant: 'Hóa đơn điện tử / App'&lt;br/&gt;Amount: max(currency nums) trong top 45%&lt;br/&gt;Date: extract_vietnamese_date() ||&lt;br/&gt;       extract_standard_date()&lt;br/&gt;&lt;i&gt;'DD tháng MM năm YYYY' → ISO&lt;/i&gt;"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0369A1;strokeColor=#075985;fontColor=#FFFFFF;fontSize=11;align=left;"
      vertex="1" parent="1">
      <mxGeometry x="80" y="1375" width="270" height="195" as="geometry" />
    </mxCell>

    <!-- Strategy 2: TABULAR -->
    <mxCell id="19" value="&lt;b&gt;⑩b Strategy 2: TABULAR&lt;/b&gt;&lt;br/&gt;&lt;i&gt;Kích hoạt: 'gtgt' | 'dien luc' | 'mau so'&lt;/i&gt;&lt;br/&gt;&lt;b&gt;EVN / Hóa đơn GTGT&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;Merchant: top 20%, tìm 'cong ty'/'dien luc'&lt;br/&gt;  (skip 'mau so', 'ky hieu')&lt;br/&gt;Amount: tìm 'tong cong'/'thanh toan'&lt;br/&gt;  → same Y-axis (±25px) → rightmost block&lt;br/&gt;Date: extract_standard_date() 'DD/MM/YYYY'"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0369A1;strokeColor=#075985;fontColor=#FFFFFF;fontSize=11;align=left;"
      vertex="1" parent="1">
      <mxGeometry x="500" y="1490" width="270" height="210" as="geometry" />
    </mxCell>

    <!-- Strategy 3: RETAIL -->
    <mxCell id="20" value="&lt;b&gt;⑩c Strategy 3: RETAIL (Default)&lt;/b&gt;&lt;br/&gt;&lt;i&gt;Không khớp 2 pattern trên&lt;/i&gt;&lt;br/&gt;&lt;b&gt;Katinat / Bong Trà / Cửa hàng lẻ&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;Merchant: top 15%, join 2 blocks đầu&lt;br/&gt;  (skip status bar: HH:MM, %)&lt;br/&gt;Blacklist: 'chiet khau','giam','khuyen mai'&lt;br/&gt;Amount: tìm 'thanh toan'/'tong tien'&lt;br/&gt;  → same block || same Y (±25px)&lt;br/&gt;  Fallback: max() in bottom 30%&lt;br/&gt;Date: extract_standard_date()"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0369A1;strokeColor=#075985;fontColor=#FFFFFF;fontSize=11;align=left;"
      vertex="1" parent="1">
      <mxGeometry x="900" y="1375" width="290" height="230" as="geometry" />
    </mxCell>

    <!-- Fallback merge -->
    <mxCell id="21" value="&lt;b&gt;⑪ Fallback cho trường rỗng&lt;/b&gt;&lt;br/&gt;merchantName = 'Không rõ' nếu rỗng&lt;br/&gt;totalAmount = 0 nếu không tìm được số tiền&lt;br/&gt;transactionDate = now() (UTC) nếu không có ngày"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7C3AED;strokeColor=#6D28D9;fontColor=#FFFFFF;fontSize=11;"
      vertex="1" parent="1">
      <mxGeometry x="380" y="1660" width="510" height="80" as="geometry" />
    </mxCell>

    <!-- Return to service-transaction -->
    <mxCell id="22" value="&lt;b&gt;⑫ ai-service Response (HTTP 200)&lt;/b&gt;&lt;br/&gt;{&quot;success&quot;: true, &quot;data&quot;: {merchantName, totalAmount, transactionDate}}&lt;br/&gt;→ service-transaction normalizeAmount() + normalizeDate()"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#16A34A;strokeColor=#15803D;fontColor=#FFFFFF;fontSize=11;"
      vertex="1" parent="1">
      <mxGeometry x="380" y="1790" width="510" height="75" as="geometry" />
    </mxCell>

    <!-- Delete temp file -->
    <mxCell id="23" value="&lt;b&gt;⑬ Cleanup — unlink(file.path)&lt;/b&gt;&lt;br/&gt;Xóa file tạm khỏi /public/uploads/ sau khi xử lý&lt;br/&gt;&lt;i&gt;(finally block — luôn chạy dù thành công hay lỗi)&lt;/i&gt;"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#16A34A;strokeColor=#15803D;fontColor=#FFFFFF;fontSize=11;strokeDashArray=5 5;"
      vertex="1" parent="1">
