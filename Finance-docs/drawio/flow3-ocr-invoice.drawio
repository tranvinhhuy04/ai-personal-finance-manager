          <mxPoint x="1020" y="500" />
          <mxPoint x="635" y="500" />
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- extractFromImage → fetch -->
    <mxCell id="56" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#16A34A;strokeWidth=2;" edge="1" source="9" target="10" parent="1">
