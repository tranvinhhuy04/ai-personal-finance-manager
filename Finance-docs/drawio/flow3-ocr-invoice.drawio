    <!-- fetch → Connection decision -->
    <mxCell id="57" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#F59E0B;strokeWidth=2;" edge="1" source="10" target="11" parent="1">
