    <!-- NOTES -->
    <mxCell id="40" value="&lt;b&gt;⚡ Currency Number Regex:&lt;/b&gt;&lt;br/&gt;\d{1,3}(?:[.,]\d{3})+&lt;br/&gt;Min value ≥ 1,000&lt;br/&gt;&lt;br/&gt;&lt;b&gt;📅 Date Patterns:&lt;/b&gt;&lt;br/&gt;• DD/MM/YYYY hoặc DD-MM-YYYY&lt;br/&gt;• DD tháng MM năm YYYY&lt;br/&gt;&lt;br/&gt;&lt;b&gt;normalize_text():&lt;/b&gt;&lt;br/&gt;NFD → strip Mn → đ→d&lt;br/&gt;→ lowercase → rm special"
      style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#FFFBEB;strokeColor=#F59E0B;fontColor=#92400E;fontSize=10;size=15;align=left;"
      vertex="1" parent="1">
      <mxGeometry x="1110" y="1100" width="230" height="210" as="geometry" />
    </mxCell>

    <mxCell id="41" value="&lt;b&gt;🐍 PaddleOCR Singleton:&lt;/b&gt;&lt;br/&gt;Thread-safe lazy init&lt;br/&gt;Double-Checked Locking&lt;br/&gt;(_ocr_lock threading.Lock)&lt;br/&gt;Chỉ download model 1 lần&lt;br/&gt;Cold start: ~30s&lt;br/&gt;Sau đó: 1-3s per image"
      style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#FFFBEB;strokeColor=#F59E0B;fontColor=#92400E;fontSize=10;size=15;align=left;"
      vertex="1" parent="1">
      <mxGeometry x="950" y="970" width="205" height="160" as="geometry" />
    </mxCell>

    <!-- ═══ EDGES ═══ -->

    <!-- START → Client -->
    <mxCell id="50" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#374151;strokeWidth=2;" edge="1" source="3" target="4" parent="1">
