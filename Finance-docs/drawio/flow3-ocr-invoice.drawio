    <!-- Client prefill form -->
    <mxCell id="25" value="&lt;b&gt;⑮ Client — Prefill Form + User Review&lt;/b&gt;&lt;br/&gt;Hiển thị ảnh hóa đơn + form điền sẵn&lt;br/&gt;User chỉnh sửa nếu cần → nhấn &quot;Lưu hóa đơn&quot;"
