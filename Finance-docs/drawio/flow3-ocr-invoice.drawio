    <!-- Decision → extractFromImage (valid) -->
    <mxCell id="55" value="Hợp lệ ✓" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#16A34A;strokeWidth=2;" edge="1" source="7" target="9" parent="1">
