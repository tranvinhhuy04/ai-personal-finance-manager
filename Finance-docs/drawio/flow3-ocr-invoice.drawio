    <!-- Return to client -->
    <mxCell id="24" value="&lt;b&gt;⑭ API Gateway → Client (HTTP 200)&lt;/b&gt;&lt;br/&gt;{success: true, data: {merchantName, totalAmount, transactionDate}}"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0284C7;strokeColor=#075985;fontColor=#FFFFFF;fontSize=11;"
      vertex="1" parent="1">
      <mxGeometry x="380" y="1920" width="510" height="65" as="geometry" />
