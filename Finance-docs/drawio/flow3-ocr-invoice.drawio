    <!-- extractFromImage -->
    <mxCell id="9" value="&lt;b&gt;④ InvoiceExtractionService.extractFromImage(filePath)&lt;/b&gt;&lt;br/&gt;readFile(path) → Buffer → Uint8Array → Blob(mimeType)&lt;br/&gt;Build FormData.append('file', blob, 'invoice.ext')"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#16A34A;strokeColor=#15803D;fontColor=#FFFFFF;fontSize=11;"
      vertex="1" parent="1">
      <mxGeometry x="380" y="515" width="510" height="75" as="geometry" />
    </mxCell>

    <!-- Call ai-service -->
    <mxCell id="10" value="&lt;b&gt;⑤ fetch() — Gọi nội bộ Docker&lt;/b&gt;&lt;br/&gt;POST http://ai-service:8000/api/v1/ai/ocr&lt;br/&gt;Content-Type: multipart/form-data | timeout: 120s&lt;br/&gt;&lt;i&gt;(PaddleOCR cold start lần đầu ~30s)&lt;/i&gt;"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#16A34A;strokeColor=#15803D;fontColor=#FFFFFF;fontSize=11;"
      vertex="1" parent="1">
      <mxGeometry x="380" y="630" width="510" height="80" as="geometry" />
