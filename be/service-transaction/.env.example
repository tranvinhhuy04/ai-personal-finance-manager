# Transaction Service Configuration
PORT=3003
NODE_ENV=development

# MongoDB Connection (Database per Service)
MONGODB_URI=mongodb://localhost:27017/transaction-service

# RabbitMQ Connection
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# JWT Secret (shared with API Gateway and other services)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Cloud invoice extraction (Google Vision + Gemini)
GEMINI_API_KEY=your_google_ai_api_key_here
GEMINI_INVOICE_MODEL=gemini-2.5-flash

# Option A: absolute path to a service-account JSON file inside the container or local machine
GOOGLE_APPLICATION_CREDENTIALS=

# Option B: paste the service-account JSON into one env var (useful for Docker/local dev)
GCP_VISION_CREDENTIALS_JSON=
GOOGLE_CLOUD_PROJECT=
